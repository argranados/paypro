{
  "info": {
    "name": "PayPro API (with API Key)",
    "_postman_id": "12345678-abcd-efgh-ijkl-987654321000",
    "description": "Colección para probar la API de pagos de PayPro con autenticación por API Key",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Payment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-API-KEY",
            "value": "{{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"merchant\": \"Store123\",\n  \"amount\": 100.50,\n  \"currency\": \"USD\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/payments",
          "host": ["{{baseUrl}}"],
          "path": ["payments"]
        }
      }
    },
    {
      "name": "Get Payment by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-KEY",
            "value": "{{apiKey}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/payments/{{paymentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["payments", "{{paymentId}}"]
        }
      }
    },
    {
      "name": "Get All Payments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-KEY",
            "value": "{{apiKey}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/payments",
          "host": ["{{baseUrl}}"],
          "path": ["payments"]
        }
      }
    }
  ]
}